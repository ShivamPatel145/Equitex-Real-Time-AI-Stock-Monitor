# Copy this file to .env or .env.local and fill in real values.

NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster-url/database-name?retryWrites=true&w=majority

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Inngest
INNGEST_EVENT_KEY=replace-with-your-inngest-event-key
INNGEST_SIGNING_KEY=replace-with-your-inngest-signing-key
INNGEST_SIGNING_KEY_FALLBACK=replace-with-your-fallback-signing-key

# AI Provider
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Email (Gmail SMTP)
NODEMAILER_EMAIL=you@gmail.com
NODEMAILER_PASSWORD=your-app-password
